$Common = "../../Common.ui";

$Common.@PageOverlay {
    LayoutMode: Center;
    Padding: (Top: 50, Bottom: 70, Left: 20, Right: 20);
    
    $Common.@DecoratedContainer {
        @CloseButton = true;
        Anchor: (Width: 600);
        
        #Title {
            $Common.@Title { @Text = "AutoPickup Settings"; }
        }
        
        #Content {
            LayoutMode: Top;
            
            Group {
                LayoutMode: Left;
                Background: #1a1a2e;
                OutlineColor: #93844c(0.3);
                OutlineSize: 1;
                Padding: (Full: 16);
                Anchor: (Bottom: 16);
                
                Group {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    
                    Label {
                        Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
                        Text: "AutoPickup Status";
                        Anchor: (Bottom: 4);
                    }
                    
                    Label #StatusLabel {
                        Style: (FontSize: 14, TextColor: #ef4444, RenderBold: true, RenderUppercase: true);
                        Text: "DISABLED";
                    }
                }
                
                Group { Anchor: (Width: 12); }
                
                $Common.@TextButton #ToggleBtn {
                    @Text = "Toggle";
                    Anchor: (Width: 120, Vertical: 0);
                }
            }
            
            Group {
                LayoutMode: Top;
                Background: #1a1a2e;
                OutlineColor: #93844c(0.3);
                OutlineSize: 1;
                Padding: (Full: 16);
                Anchor: (Bottom: 16);
                
                Group {
                    LayoutMode: Left;
                    Anchor: (Bottom: 8);
                    
                    Label {
                        Style: (FontSize: 12, TextColor: #64748b, RenderUppercase: true);
                        Text: "Pickup Radius";
                        FlexWeight: 1;
                    }
                    
                    Label #RadiusLabel {
                        Style: (FontSize: 14, TextColor: #ffaa00, RenderBold: true);
                        Text: "5";
                    }
                    
                    Label {
                        Style: (FontSize: 14, TextColor: #64748b);
                        Text: " blocks";
                    }
                }
                
                Slider #RadiusSlider {
                    Style: $Common.@DefaultSliderStyle;
                    Min: 0;
                    Max: 10;
                    Value: 5;
                }
                
                Label {
                    Style: (FontSize: 11, TextColor: #64748b, HorizontalAlignment: Center);
                    Text: "How far away items can be to get auto-picked up";
                    Anchor: (Top: 6);
                }
            }
            
            $Common.@PanelTitle {
                @Text = "Notification Settings";
                Anchor: (Bottom: 12);
            }
            
            Group {
                LayoutMode: Top;
                Background: #1a1a2e;
                OutlineColor: #93844c(0.3);
                OutlineSize: 1;
                Padding: (Full: 16);
                Anchor: (Bottom: 12);
                
                Label {
                    Style: (FontSize: 12, TextColor: #64748b, RenderUppercase: true);
                    Text: "Toggle Notification Type";
                    Anchor: (Bottom: 6);
                }
                
                Group {
                    LayoutMode: Left;
                    Anchor: (Bottom: 12);
                    
                    Label {
                        Style: (FontSize: 14, TextColor: #93844c, RenderBold: true);
                        Text: "Enable/Disable:";
                        Anchor: (Vertical: 0);
                    }
                    
                    Label { FlexWeight: 1; }
                    
                    Label #ToggleNotifType {
                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                        Text: "TITLE";
                        Anchor: (Vertical: 0);
                    }
                }
                
                Label {
                    Style: (FontSize: 12, TextColor: #64748b, RenderUppercase: true);
                    Text: "Pickup Notification Type";
                    Anchor: (Bottom: 6);
                }
                
                Group {
                    LayoutMode: Left;
                    
                    Label {
                        Style: (FontSize: 14, TextColor: #93844c, RenderBold: true);
                        Text: "Item Pickup:";
                        Anchor: (Vertical: 0);
                    }
                    
                    Label { FlexWeight: 1; }
                    
                    Label #PickupNotifType {
                        Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                        Text: "NOTIFICATION";
                        Anchor: (Vertical: 0);
                    }
                }
            }
            
            Label {
                Style: (FontSize: 12, TextColor: #64748b, HorizontalAlignment: Center);
                Text: "Notification types: TITLE, NOTIFICATION, CHAT, NONE";
                Anchor: (Bottom: 12);
            }
            
            Label {
                Style: (FontSize: 11, TextColor: #64748b, HorizontalAlignment: Center);
                Text: "Contact an admin to change notification types";
            }
        }
    }
    
    $Common.@BackButton {}
}